						},
						"url": {
							"raw": "{{base_url}}/api/problems",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"problems"
							]
						},
						"description": "Adds a new DSA problem. Requires Bearer Token. Only allowed if user email ends with @placementprep.com or is admin@gmail.com."
					},
					"response": []
				},
