							],
							"path": [
								"api",
								"hello"
							]
						},
						"description": "Public endpoint to verify the Spring Boot server is active."
					},
					"response": []
				}
			]
		},
		{
			"name": "DSA Problems",
			"item": [
				{
					"name": "Add Problem (Admin Only)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwt_token}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
